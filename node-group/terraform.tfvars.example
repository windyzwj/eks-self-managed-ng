###############################################################################
# From the prerequisites stack outputs (terraform output node_group_tfvars_hint)
###############################################################################
region                         = "us-east-1"
cluster_name                   = "my-eks-cluster"
existing_node_role_arn         = "arn:aws:iam::123456789012:role/eks-gpu-node-role"
existing_instance_profile_name = "eks-gpu-node-profile"
existing_node_sg_id            = "sg-xxxxxxxxxxxxxxxxx"
cluster_security_group_id      = "sg-yyyyyyyyyyyyyyyyy"
vpc_id                         = "vpc-xxxxxxxxxxxxxxxxx"

###############################################################################
# Cluster connection (aws eks describe-cluster)
###############################################################################
cluster_endpoint  = "https://XXXXXXXX.gr7.us-east-1.eks.amazonaws.com"
cluster_ca        = "LS0tLS1CRUdJTiBDRVJUSUZJQ0FURS0tLS0t..."  # base64, raw value
service_ipv4_cidr = "172.20.0.0/16"                            # your cluster's actual service CIDR

###############################################################################
# This node group
###############################################################################
name_prefix   = "eks-gpu-b300-odcr1"   # UNIQUE per pool
instance_type = "p6-b300.48xlarge"
eks_version   = "1.35"

subnet_ids   = ["subnet-xxxxxxxxxxxxxxxxx"]  # single AZ for ODCR/CB
desired_size = 1
min_size     = 0
max_size     = 1

# Pricing: on_demand | spot | odcr | capacity_block
purchase_mode           = "odcr"
capacity_reservation_id = "cr-xxxxxxxxxxxxxxxxx"   # required for odcr / capacity_block
# placement_group_name  = "my-cluster-pg"          # recommended for single-AZ multi-node NCCL

# AMI: empty release version = SSM 'recommended'; pin for reproducibility
# gpu_ami_release_version = "v20260527"
# custom_ami_id           = "ami-xxxxxxxx"   # operator-baked AMI (overrides the above)

# EFA userspace: true = install libfabric at first boot (nodes have NAT).
# false = expect a custom AMI with libfabric pre-baked (fully air-gapped nodes).
install_efa_userspace = true
efa_installer_version = "1.48.0"

# root_volume_size = 300
# data_volume_size = 100

# extra_node_labels = { team = "research" }
# extra_asg_tags    = { Owner = "ml-platform", CostCenter = "1234" }

###############################################################################
# Spot 示例（替换上面的 purchase_mode / capacity_reservation_id 段）
###############################################################################
# name_prefix   = "eks-gpu-b300-spot"
# instance_type = "p6-b300.48xlarge"
# purchase_mode = "spot"
# # capacity_reservation_id 不需要
# # placement_group_name 可选（spot 不保证同 AZ 能拿到，不推荐 cluster PG）
# subnet_ids    = ["subnet-aaa", "subnet-bbb"]  # 多 AZ 增加 spot 命中率
# desired_size  = 1
# min_size      = 0
# max_size      = 4
#
# # Spot 行为说明：
# #   - LT 里 instance_market_options = { market_type = "spot" }
# #   - spot_instance_type = "one-time"（中断后不自动重新请求）
# #   - instance_interruption_behavior = "terminate"（被回收直接终止）
# #   - ASG suspended_processes=[ReplaceUnhealthy,AZRebalance] 照样生效：
# #     spot 被回收 → 实例消失 → ASG desired 比 running 多 1 →
# #     ASG 自动在 spot 池里再起一台（用 Launch process，没 suspend）
# #   - 如果 spot 池子没容量 → InsufficientInstanceCapacity 等到有为止
# #   - 要完全不自动补，手动把 desired 减 1（或让 CA 决定）
